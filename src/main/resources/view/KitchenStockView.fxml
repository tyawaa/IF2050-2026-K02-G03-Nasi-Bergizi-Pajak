<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.geometry.Rectangle2D?>
<?import java.lang.String?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="nasi_bergizi_pajak.controller.KitchenStockViewController"
            stylesheets="@../auth.css"
            styleClass="dashboard-root">

    <!-- ══════════════════ HEADER ══════════════════ -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="14" styleClass="dashboard-header">
            <padding>
                <Insets top="18" right="28" bottom="18" left="28"/>
            </padding>
            <StackPane styleClass="brand-image-mark-small">
                <ImageView fitWidth="44" fitHeight="44" preserveRatio="true">
                    <viewport>
                        <Rectangle2D minX="33" minY="30" width="86" height="86"/>
                    </viewport>
                    <image>
                        <Image url="@../img/logo_nasibergizipajak.png"/>
                    </image>
                </ImageView>
            </StackPane>
            <VBox spacing="0">
                <Label text="Nasi Bergizi Pajak" styleClass="dashboard-brand"/>
                <Label text="Manajemen Stok Dapur" styleClass="dashboard-subtitle"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Dashboard" onAction="#handleBackToDashboard" styleClass="button-outline"/>
            <Button text="Logout" onAction="#handleLogout" styleClass="button-outline"/>
        </HBox>
    </top>

    <!-- ══════════════════ MAIN CONTENT ══════════════════ -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="auth-scroll">
            <VBox spacing="20">
                <padding>
                    <Insets top="24" right="28" bottom="28" left="28"/>
                </padding>

                <!-- Page Title -->
                <VBox spacing="4">
                    <Label text="Stok Dapur" styleClass="page-title"/>
                    <Label text="Pantau dan kelola bahan makanan dapur Anda" styleClass="page-subtitle"/>
                </VBox>

                <!-- ── STAT CARDS ── -->
                <HBox spacing="16">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <styleClass>
                            <String fx:value="stat-card"/>
                            <String fx:value="stat-card-total"/>
                        </styleClass>
                        <Label fx:id="statTotalLabel" text="0" styleClass="stat-number"/>
                        <Label text="Total Item" styleClass="stat-label"/>
                    </VBox>
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <styleClass>
                            <String fx:value="stat-card"/>
                            <String fx:value="stat-card-low"/>
                        </styleClass>
                        <Label fx:id="statLowLabel" text="0" styleClass="stat-number"/>
                        <Label text="Stok Rendah" styleClass="stat-label"/>
                    </VBox>
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <styleClass>
                            <String fx:value="stat-card"/>
                            <String fx:value="stat-card-expiring"/>
                        </styleClass>
                        <Label fx:id="statExpiringLabel" text="0" styleClass="stat-number"/>
                        <Label text="Hampir Kadaluarsa" styleClass="stat-label"/>
                    </VBox>
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <styleClass>
                            <String fx:value="stat-card"/>
                            <String fx:value="stat-card-expired"/>
                        </styleClass>
                        <Label fx:id="statExpiredLabel" text="0" styleClass="stat-number"/>
                        <Label text="Kadaluarsa" styleClass="stat-label"/>
                    </VBox>
                </HBox>

                <!-- ── TABLE SECTION ── -->
                <VBox spacing="12" styleClass="table-section">

                    <!-- Toolbar: search + refresh -->
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <TextField fx:id="searchField" promptText="Cari nama bahan..." prefWidth="280" styleClass="auth-input"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="Refresh" onAction="#handleRefresh" styleClass="button-outline"/>
                    </HBox>

                    <!-- Filter Tabs -->
                    <HBox spacing="8">
                        <Button fx:id="filterAllBtn" text="Semua" onAction="#handleFilterAll">
                            <styleClass>
                                <String fx:value="filter-tab"/>
                                <String fx:value="filter-tab-active"/>
                            </styleClass>
                        </Button>
                        <Button fx:id="filterLowBtn" text="Stok Rendah" onAction="#handleFilterLow" styleClass="filter-tab"/>
                        <Button fx:id="filterExpiringBtn" text="Hampir Kadaluarsa" onAction="#handleFilterExpiring" styleClass="filter-tab"/>
                        <Button fx:id="filterExpiredBtn" text="Kadaluarsa" onAction="#handleFilterExpired" styleClass="filter-tab"/>
                    </HBox>

                    <!-- Data Table -->
                    <TableView fx:id="stockTable" prefHeight="300" styleClass="stock-table">
                        <columns>
                            <TableColumn fx:id="colNo"         text="No"           prefWidth="50"  minWidth="50"  maxWidth="60"/>
                            <TableColumn fx:id="colNama"       text="Nama Bahan"   prefWidth="200" minWidth="140"/>
                            <TableColumn fx:id="colJumlah"     text="Jumlah"       prefWidth="80"  minWidth="65"/>
                            <TableColumn fx:id="colSatuan"     text="Satuan"       prefWidth="80"  minWidth="65"/>
                            <TableColumn fx:id="colLokasi"     text="Lokasi"       prefWidth="140" minWidth="100"/>
                            <TableColumn fx:id="colKadaluarsa" text="Kadaluarsa"   prefWidth="115" minWidth="100"/>
                            <TableColumn fx:id="colStatus"     text="Status"       prefWidth="135" minWidth="110"/>
                            <TableColumn fx:id="colAksi"       text="Aksi"         prefWidth="155" minWidth="140"/>
                        </columns>
                        <placeholder>
                            <Label text="Tidak ada data stok. Tambahkan stok baru di bawah." styleClass="muted-text"/>
                        </placeholder>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                    </TableView>
                </VBox>

                <!-- ── FORM SECTION ── -->
                <VBox spacing="16" styleClass="form-section">

                    <!-- Form Header -->
                    <HBox alignment="CENTER_LEFT">
                        <Label fx:id="formTitleLabel" text="Tambah Stok Baru" styleClass="form-section-title"/>
                    </HBox>

                    <!-- Message Box -->
                    <Label fx:id="messageLabel" styleClass="message-box" wrapText="true" visible="false"/>

                    <!-- Form Fields -->
                    <GridPane hgap="16" vgap="12">
                        <columnConstraints>
                            <ColumnConstraints prefWidth="140" minWidth="120"/>
                            <ColumnConstraints hgrow="ALWAYS" fillWidth="true"/>
                            <ColumnConstraints prefWidth="90"  minWidth="75"/>
                            <ColumnConstraints prefWidth="160" minWidth="140"/>
                        </columnConstraints>

                        <!-- Row 0: Nama Bahan -->
                        <Label text="Nama Bahan" styleClass="input-label"
                               GridPane.rowIndex="0" GridPane.columnIndex="0" GridPane.valignment="CENTER"/>
                        <ComboBox fx:id="ingredientCombo" editable="true"
                                  promptText="Pilih atau ketik nama bahan"
                                  maxWidth="Infinity"
                                  GridPane.rowIndex="0" GridPane.columnIndex="1" GridPane.columnSpan="3"/>

                        <!-- Row 1: Jumlah + Satuan -->
                        <Label text="Jumlah" styleClass="input-label"
                               GridPane.rowIndex="1" GridPane.columnIndex="0" GridPane.valignment="CENTER"/>
                        <TextField fx:id="quantityField" promptText="cth: 1.5" styleClass="auth-input"
                                   GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                        <Label text="Satuan" styleClass="input-label"
                               GridPane.rowIndex="1" GridPane.columnIndex="2" GridPane.valignment="CENTER"/>
                        <TextField fx:id="unitField" promptText="cth: kg, liter" styleClass="auth-input"
                                   GridPane.rowIndex="1" GridPane.columnIndex="3"/>

                        <!-- Row 2: Lokasi + Kadaluarsa -->
                        <Label text="Lokasi Simpan" styleClass="input-label"
                               GridPane.rowIndex="2" GridPane.columnIndex="0" GridPane.valignment="CENTER"/>
                        <TextField fx:id="locationField" promptText="cth: Kulkas, Lemari" styleClass="auth-input"
                                   GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                        <Label text="Kadaluarsa" styleClass="input-label"
                               GridPane.rowIndex="2" GridPane.columnIndex="2" GridPane.valignment="CENTER"/>
                        <DatePicker fx:id="expiryDatePicker" maxWidth="Infinity"
                                    GridPane.rowIndex="2" GridPane.columnIndex="3"/>
                    </GridPane>

                    <!-- Form Buttons -->
                    <HBox spacing="12">
                        <Button fx:id="saveButton" text="Simpan" onAction="#handleSave"
                                styleClass="button-primary" prefWidth="120"/>
                        <Button fx:id="cancelButton" text="Batal" onAction="#handleClearForm"
                                styleClass="button-outline" prefWidth="100"/>
                    </HBox>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
