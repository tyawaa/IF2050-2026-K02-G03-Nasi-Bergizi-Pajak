<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.geometry.Rectangle2D?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="nasi_bergizi_pajak.controller.DashboardController"
            stylesheets="@../auth.css"
            styleClass="dashboard-root">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="14" styleClass="dashboard-header">
            <padding>
                <Insets top="18" right="28" bottom="18" left="28"/>
            </padding>
            <StackPane styleClass="brand-image-mark-small">
                <ImageView fitWidth="44" fitHeight="44" preserveRatio="true" styleClass="brand-logo-image">
                    <viewport>
                        <Rectangle2D minX="33" minY="30" width="86" height="86"/>
                    </viewport>
                    <image>
                        <Image url="@../img/logo_nasibergizipajak.png"/>
                    </image>
                </ImageView>
            </StackPane>
            <VBox spacing="0">
                <Label text="Nasi Bergizi Pajak" styleClass="dashboard-brand"/>
                <Label text="Dashboard sementara untuk validasi login" styleClass="dashboard-subtitle"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Logout" onAction="#handleLogout" styleClass="button-outline"/>
        </HBox>
    </top>
    <center>
        <StackPane>
            <VBox alignment="CENTER" spacing="16" maxWidth="520" styleClass="dashboard-card">
                <Label fx:id="welcomeLabel" text="Halo!" styleClass="dashboard-title"/>
                <Label fx:id="emailLabel" text="" styleClass="dashboard-email"/>
                <Separator/>
                <Label text="Kelola daftar belanja dari menu mingguan dan sinkronkan hasil belanja ke stok dapur." wrapText="true" styleClass="dashboard-note"/>
                <Button text="Buka Planner Belanja" onAction="#handleOpenShoppingPlanner" styleClass="button-secondary"/>
            </VBox>
        </StackPane>
    </center>
</BorderPane>
