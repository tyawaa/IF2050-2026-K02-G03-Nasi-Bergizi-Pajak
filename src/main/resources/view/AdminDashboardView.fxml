<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.geometry.Rectangle2D?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="adminRoot"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="nasi_bergizi_pajak.controller.AdminDashboardController"
            stylesheets="@../auth.css"
            styleClass="admin-shell">
    <left>
        <VBox spacing="18" styleClass="admin-sidebar">
            <padding>
                <Insets top="12" right="10" bottom="14" left="10"/>
            </padding>
            <HBox spacing="10" styleClass="admin-brand-row">
                <StackPane styleClass="admin-logo-box">
                    <ImageView fitWidth="36" fitHeight="36" preserveRatio="true">
                        <viewport>
                            <Rectangle2D minX="33" minY="30" width="86" height="86"/>
                        </viewport>
                        <image>
                            <Image url="@../img/logo_nasibergizipajak.png"/>
                        </image>
                    </ImageView>
                </StackPane>
                <VBox spacing="0">
                    <Label text="Nasi Bergizi" styleClass="admin-brand-title"/>
                    <Label text="Pajak" styleClass="admin-brand-subtitle"/>
                </VBox>
            </HBox>

            <VBox spacing="8">
                <Label text="ADMIN" styleClass="admin-sidebar-label"/>
                <Button fx:id="btnResep"
                        text="Kelola Resep"
                        onAction="#handleResep"
                        styleClass="admin-nav-button"/>
                <Button fx:id="btnBahanHarga"
                        text="Bahan &amp; Harga"
                        onAction="#handleBahanHarga"
                        styleClass="admin-nav-button"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <Button fx:id="btnLogout"
                    text="Logout"
                    onAction="#handleLogout"
                    styleClass="admin-logout-button"/>
        </VBox>
    </left>

    <top>
        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="admin-topbar">
            <padding>
                <Insets top="10" right="18" bottom="10" left="18"/>
            </padding>
            <Label fx:id="headerTitle" text="Admin: Kelola Resep" styleClass="admin-page-title"/>
            <Label text="Budget: 22 Apr - 28 Apr" styleClass="admin-budget-badge"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="!" styleClass="admin-top-icon"/>
            <Label text="3" styleClass="admin-notif-badge"/>
            <Label text="B" styleClass="admin-avatar"/>
            <Label fx:id="userLabel" text="Budi" styleClass="admin-user-name"/>
        </HBox>
    </top>

    <center>
        <StackPane fx:id="contentPane" styleClass="admin-content"/>
    </center>
</BorderPane>
