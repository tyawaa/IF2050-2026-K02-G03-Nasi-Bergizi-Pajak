<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.geometry.Rectangle2D?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="nasi_bergizi_pajak.controller.ShoppingPlannerController"
            stylesheets="@../auth.css"
            styleClass="dashboard-root">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="14" styleClass="dashboard-header">
            <padding>
                <Insets top="18" right="28" bottom="18" left="28"/>
            </padding>
            <StackPane styleClass="brand-image-mark-small">
                <ImageView fitWidth="44" fitHeight="44" preserveRatio="true" styleClass="brand-logo-image">
                    <viewport>
                        <Rectangle2D minX="33" minY="30" width="86" height="86"/>
                    </viewport>
                    <image>
                        <Image url="@../img/logo_nasibergizipajak.png"/>
                    </image>
                </ImageView>
            </StackPane>
            <VBox spacing="0">
                <Label text="Financial &amp; Shopping Planner" styleClass="dashboard-brand"/>
                <Label text="UC11 daftar belanja dan UC12 hasil belanja" styleClass="dashboard-subtitle"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Dashboard" onAction="#handleBackToDashboard" styleClass="button-outline"/>
        </HBox>
    </top>
    <center>
        <VBox spacing="18" styleClass="shopping-page">
            <padding>
                <Insets top="24" right="28" bottom="24" left="28"/>
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="14">
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="Menu mingguan" styleClass="input-label"/>
                    <ComboBox fx:id="menuComboBox" maxWidth="Infinity" onAction="#handleMenuChanged" styleClass="auth-input"/>
                </VBox>
                <Button text="Susun Daftar Belanja" onAction="#handleGenerateShoppingList" styleClass="button-primary"/>
            </HBox>

            <GridPane hgap="12" vgap="12">
                <columnConstraints>
                    <ColumnConstraints percentWidth="25"/>
                    <ColumnConstraints percentWidth="25"/>
                    <ColumnConstraints percentWidth="25"/>
                    <ColumnConstraints percentWidth="25"/>
                </columnConstraints>
                <Label fx:id="plannerStatusLabel" text="Status: -" styleClass="summary-tile" GridPane.columnIndex="0"/>
                <Label fx:id="estimationLabel" text="Estimasi: -" styleClass="summary-tile" GridPane.columnIndex="1"/>
                <Label fx:id="budgetLabel" text="Budget: -" styleClass="summary-tile" GridPane.columnIndex="2"/>
                <Label fx:id="actualLabel" text="Aktual dipilih: -" styleClass="summary-tile" GridPane.columnIndex="3"/>
            </GridPane>

            <Label fx:id="messageLabel" text="" wrapText="true" styleClass="message-success"/>

            <TableView fx:id="itemTable" editable="true" VBox.vgrow="ALWAYS" styleClass="shopping-table">
                <columns>
                    <TableColumn fx:id="ingredientColumn" text="Bahan" prefWidth="250"/>
                    <TableColumn fx:id="quantityColumn" text="Jumlah Beli" prefWidth="150"/>
                    <TableColumn fx:id="estimationColumn" text="Estimasi" prefWidth="170"/>
                    <TableColumn fx:id="actualColumn" text="Harga Aktual" prefWidth="170"/>
                    <TableColumn fx:id="boughtColumn" text="Dibeli" prefWidth="90"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>

            <HBox alignment="CENTER_LEFT" spacing="12" styleClass="shopping-editor">
                <VBox spacing="6">
                    <Label text="Harga aktual item terpilih" styleClass="input-label"/>
                    <TextField fx:id="actualPriceField" promptText="contoh: 25000" styleClass="auth-input"/>
                </VBox>
                <CheckBox fx:id="boughtCheckBox" text="Sudah dibeli" styleClass="small-check"/>
                <Button text="Terapkan Item" onAction="#handleApplySelectedActual" styleClass="button-outline"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Pakai Estimasi" onAction="#handleUseEstimationAsActual" styleClass="button-outline"/>
                <Button fx:id="processButton" text="Proses Hasil Belanja" onAction="#handleProcessShoppingResult" styleClass="button-secondary"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>
