<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.geometry.Rectangle2D?>
<?import java.lang.String?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="nasi_bergizi_pajak.controller.LoginController"
      stylesheets="@../auth.css"
      styleClass="auth-root">

    <VBox prefWidth="590" HBox.hgrow="ALWAYS">
        <styleClass>
            <String fx:value="auth-side"/>
            <String fx:value="auth-side-login"/>
        </styleClass>
        <padding>
            <Insets top="48" right="42" bottom="42" left="42"/>
        </padding>

        <HBox alignment="CENTER_LEFT" spacing="14">
            <StackPane>
                <styleClass>
                    <String fx:value="brand-image-mark"/>
                </styleClass>
                <ImageView fitWidth="56" fitHeight="56" preserveRatio="true" styleClass="brand-logo-image">
                    <viewport>
                        <Rectangle2D minX="33" minY="30" width="86" height="86"/>
                    </viewport>
                    <image>
                        <Image url="@../img/logo_nasibergizipajak.png"/>
                    </image>
                </ImageView>
            </StackPane>
            <VBox spacing="0">
                <Label text="Nasi Bergizi" styleClass="brand-title"/>
                <Label text="Pajak" styleClass="brand-subtitle"/>
            </VBox>
        </HBox>

        <Region VBox.vgrow="ALWAYS"/>

        <VBox spacing="26">
            <VBox spacing="14">
                <Label text="Rencanakan Menu Sehat,&#10;Kelola Anggaran Dapur" styleClass="hero-title" wrapText="true"/>
                <Label text="Aplikasi lengkap untuk perencanaan menu makanan keluarga, pengelolaan stok dapur, dan anggaran belanja yang cerdas."
                       styleClass="hero-subtitle" wrapText="true"/>
            </VBox>

            <HBox spacing="16">
                <VBox spacing="8" styleClass="feature-card" HBox.hgrow="ALWAYS">
                    <StackPane>
                        <styleClass>
                            <String fx:value="feature-icon"/>
                            <String fx:value="feature-icon-orange"/>
                        </styleClass>
                        <ImageView fitWidth="40" fitHeight="40" preserveRatio="true" styleClass="feature-image">
                            <viewport>
                                <Rectangle2D minX="0" minY="0" width="260" height="260"/>
                            </viewport>
                            <image>
                                <Image url="@../img/logo_menu_mingguan.png"/>
                            </image>
                        </ImageView>
                    </StackPane>
                    <Label text="Menu Mingguan" styleClass="feature-title"/>
                    <Label text="Rencana makan terstruktur" styleClass="feature-desc" wrapText="true"/>
                </VBox>
                <VBox spacing="8" styleClass="feature-card" HBox.hgrow="ALWAYS">
                    <StackPane>
                        <styleClass>
                            <String fx:value="feature-icon"/>
                            <String fx:value="feature-icon-green"/>
                        </styleClass>
                        <ImageView fitWidth="40" fitHeight="40" preserveRatio="true" styleClass="feature-image">
                            <viewport>
                                <Rectangle2D minX="0" minY="0" width="260" height="260"/>
                            </viewport>
                            <image>
                                <Image url="@../img/logo_gizi_seimbang.png"/>
                            </image>
                        </ImageView>
                    </StackPane>
                    <Label text="Gizi Seimbang" styleClass="feature-title"/>
                    <Label text="Pantau nutrisi keluarga" styleClass="feature-desc" wrapText="true"/>
                </VBox>
                <VBox spacing="8" styleClass="feature-card" HBox.hgrow="ALWAYS">
                    <StackPane>
                        <styleClass>
                            <String fx:value="feature-icon"/>
                            <String fx:value="feature-icon-yellow"/>
                        </styleClass>
                        <ImageView fitWidth="40" fitHeight="40" preserveRatio="true" styleClass="feature-image">
                            <viewport>
                                <Rectangle2D minX="0" minY="0" width="271" height="271"/>
                            </viewport>
                            <image>
                                <Image url="@../img/logo_hemat_budget.png"/>
                            </image>
                        </ImageView>
                    </StackPane>
                    <Label text="Hemat Budget" styleClass="feature-title"/>
                    <Label text="Kontrol pengeluaran" styleClass="feature-desc" wrapText="true"/>
                </VBox>
            </HBox>
        </VBox>

        <Region VBox.vgrow="ALWAYS"/>
        <Label text="&#169; 2026 Nasi Bergizi Pajak. Semua hak dilindungi." styleClass="footer-text"/>
    </VBox>

    <StackPane prefWidth="590" HBox.hgrow="ALWAYS" alignment="CENTER" styleClass="auth-form-panel">
        <VBox maxWidth="420" spacing="20">
            <styleClass>
                <String fx:value="auth-form-card"/>
                <String fx:value="auth-login-card"/>
            </styleClass>
            <VBox spacing="8">
                <Label text="Selamat Datang" styleClass="form-title"/>
                <Label text="Masuk ke akun Anda untuk melanjutkan" styleClass="form-subtitle"/>
            </VBox>

            <Label fx:id="errorLabel" styleClass="message-box" wrapText="true"/>

            <VBox spacing="8">
                <Label text="Email" styleClass="input-label"/>
                <TextField fx:id="emailField" promptText="nama@email.com" styleClass="auth-input"/>
            </VBox>

            <VBox spacing="8">
                <Label text="Password" styleClass="input-label"/>
                <StackPane>
                    <PasswordField fx:id="passwordField" promptText="Masukkan password" styleClass="auth-input"/>
                    <TextField fx:id="visiblePasswordField" promptText="Masukkan password" styleClass="auth-input"/>
                </StackPane>
                <CheckBox fx:id="showPasswordCheckBox" text="Tampilkan password" onAction="#handleTogglePassword" styleClass="small-check"/>
            </VBox>

            <Button fx:id="loginButton" text="Masuk" onAction="#handleLogin" maxWidth="Infinity" styleClass="button-primary"/>

            <HBox alignment="CENTER" spacing="4">
                <Label text="Belum punya akun?" styleClass="muted-text"/>
                <Hyperlink text="Daftar sekarang" onAction="#goToRegister">
                    <styleClass>
                        <String fx:value="auth-link"/>
                        <String fx:value="auth-link-orange"/>
                    </styleClass>
                </Hyperlink>
            </HBox>

            <VBox spacing="6" styleClass="helper-box">
                <Label text="Catatan Login" styleClass="helper-title"/>
                <Label text="Daftar akun terlebih dahulu, lalu masuk menggunakan email dan password yang sama." styleClass="helper-text" wrapText="true"/>
            </VBox>
        </VBox>
    </StackPane>
</HBox>
