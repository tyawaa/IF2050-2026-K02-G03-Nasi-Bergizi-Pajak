<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.geometry.Rectangle2D?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="nasi_bergizi_pajak.controller.ManageIngredientPriceViewController"
            stylesheets="@../auth.css"
            styleClass="dashboard-root">

    <!-- ===== HEADER ===== -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="14" styleClass="dashboard-header">
            <padding>
                <Insets top="18" right="28" bottom="18" left="28"/>
            </padding>
            <StackPane styleClass="brand-image-mark-small">
                <ImageView fitWidth="44" fitHeight="44" preserveRatio="true">
                    <viewport>
                        <Rectangle2D minX="33" minY="30" width="86" height="86"/>
                    </viewport>
                    <image>
                        <Image url="@../img/logo_nasibergizipajak.png"/>
                    </image>
                </ImageView>
            </StackPane>
            <VBox spacing="0">
                <Label text="Nasi Bergizi Pajak" styleClass="dashboard-brand"/>
                <Label text="Manajemen Harga Bahan" styleClass="dashboard-subtitle"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="&#8592; Kembali ke Dashboard" onAction="#handleBack" styleClass="button-outline"/>
        </HBox>
    </top>

    <!-- ===== CONTENT ===== -->
    <center>
        <HBox spacing="20" fillHeight="true">
            <padding>
                <Insets top="24" right="28" bottom="24" left="28"/>
            </padding>

            <!-- LEFT: Ingredient table panel -->
            <VBox spacing="14" HBox.hgrow="ALWAYS" styleClass="dashboard-card">

                <!-- Search bar -->
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="Daftar Bahan Makanan" styleClass="form-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <TextField fx:id="searchField"
                               promptText="Cari nama bahan..."
                               styleClass="auth-input"
                               prefWidth="220"
                               onKeyReleased="#handleSearch"/>
                </HBox>

                <!-- Ingredient table -->
                <TableView fx:id="ingredientTable" VBox.vgrow="ALWAYS" styleClass="ingredient-table">
                    <columns>
                        <TableColumn fx:id="colNo"    text="No."            prefWidth="55"  resizable="false"/>
                        <TableColumn fx:id="colName"  text="Nama Bahan"     prefWidth="200"/>
                        <TableColumn fx:id="colUnit"  text="Satuan"         prefWidth="90"/>
                        <TableColumn fx:id="colPrice" text="Harga Saat Ini" prefWidth="160"/>
                        <TableColumn fx:id="colDate"  text="Tgl. Berlaku"   prefWidth="130"/>
                    </columns>
                    <placeholder>
                        <Label text="Tidak ada data bahan makanan." styleClass="muted-text"/>
                    </placeholder>
                </TableView>

            </VBox>

            <!-- RIGHT: Edit price panel -->
            <VBox spacing="16" prefWidth="320" minWidth="300" styleClass="dashboard-card">

                <Label text="Edit Harga Bahan" styleClass="form-title"/>
                <Separator/>

                <!-- Selected ingredient info -->
                <VBox spacing="4">
                    <Label text="Bahan Dipilih" styleClass="input-label"/>
                    <Label fx:id="labelNamaBahan" text="— Pilih bahan dari tabel —"
                           wrapText="true" styleClass="muted-text"/>
                </VBox>

                <VBox spacing="4">
                    <Label text="Harga Saat Ini" styleClass="input-label"/>
                    <Label fx:id="labelHargaSaatIni" text="—" styleClass="muted-text"/>
                </VBox>

                <Separator/>

                <!-- New price input -->
                <VBox spacing="6">
                    <Label text="Harga Baru (Rp)" styleClass="input-label"/>
                    <TextField fx:id="fieldHargaBaru"
                               promptText="Contoh: 15000"
                               styleClass="auth-input"
                               maxWidth="Infinity"/>
                </VBox>

                <!-- Effective date -->
                <VBox spacing="6">
                    <Label text="Tanggal Berlaku" styleClass="input-label"/>
                    <DatePicker fx:id="datePickerBerlaku"
                                styleClass="date-picker-input"
                                maxWidth="Infinity"/>
                </VBox>

                <Region VBox.vgrow="ALWAYS"/>

                <!-- Save button -->
                <Button fx:id="btnSimpan"
                        text="Simpan Perubahan"
                        onAction="#handleSimpan"
                        styleClass="button-primary"
                        maxWidth="Infinity"
                        disable="true"/>

                <!-- Status message -->
                <Label fx:id="labelStatus" text="" wrapText="true"
                       styleClass="message-box" maxWidth="Infinity"/>

            </VBox>
        </HBox>
    </center>

</BorderPane>
