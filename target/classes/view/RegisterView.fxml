<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.geometry.Rectangle2D?>
<?import java.lang.String?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="nasi_bergizi_pajak.controller.RegistrasiController"
      stylesheets="@../auth.css"
      styleClass="auth-root">

    <VBox prefWidth="590" HBox.hgrow="ALWAYS">
        <styleClass>
            <String fx:value="auth-side"/>
            <String fx:value="auth-side-register"/>
        </styleClass>
        <padding>
            <Insets top="48" right="42" bottom="42" left="42"/>
        </padding>

        <HBox alignment="CENTER_LEFT" spacing="14">
            <StackPane>
                <styleClass>
                    <String fx:value="brand-image-mark"/>
                </styleClass>
                <ImageView fitWidth="56" fitHeight="56" preserveRatio="true" styleClass="brand-logo-image">
                    <viewport>
                        <Rectangle2D minX="47" minY="57" width="336" height="336"/>
                    </viewport>
                    <image>
                        <Image url="@../img/logo_nasibergizipajak_green.png"/>
                    </image>
                </ImageView>
            </StackPane>
            <VBox spacing="0">
                <Label text="Nasi Bergizi" styleClass="brand-title"/>
                <Label text="Pajak" styleClass="brand-subtitle"/>
            </VBox>
        </HBox>

        <Region VBox.vgrow="ALWAYS"/>

        <VBox spacing="22">
            <Label text="Bergabunglah dengan&#10;Keluarga Sehat Indonesia" styleClass="hero-title" wrapText="true"/>
            <Label text="Daftarkan akun Anda dan mulai perjalanan menuju gaya hidup sehat dengan perencanaan menu yang cerdas."
                   styleClass="hero-subtitle" wrapText="true"/>

            <VBox spacing="16" styleClass="step-list">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <StackPane>
                        <styleClass>
                            <String fx:value="step-badge"/>
                            <String fx:value="step-badge-active"/>
                        </styleClass>
                        <Label text="1" styleClass="step-badge-text-active"/>
                    </StackPane>
                    <Label text="Daftar akun gratis" styleClass="step-text-active"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <StackPane>
                        <styleClass>
                            <String fx:value="step-badge"/>
                            <String fx:value="step-badge-muted"/>
                        </styleClass>
                        <Label text="2" styleClass="step-badge-text-muted"/>
                    </StackPane>
                    <Label text="Tambahkan profil keluarga" styleClass="step-text-muted"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <StackPane>
                        <styleClass>
                            <String fx:value="step-badge"/>
                            <String fx:value="step-badge-muted"/>
                        </styleClass>
                        <Label text="3" styleClass="step-badge-text-muted"/>
                    </StackPane>
                    <Label text="Mulai rencana menu mingguan" styleClass="step-text-muted"/>
                </HBox>
            </VBox>
        </VBox>

        <Region VBox.vgrow="ALWAYS"/>
        <Label text="&#169; 2026 Nasi Bergizi Pajak. Semua hak dilindungi." styleClass="footer-text"/>
    </VBox>

    <StackPane prefWidth="590" HBox.hgrow="ALWAYS" styleClass="auth-form-panel">
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" styleClass="auth-scroll">
            <VBox maxWidth="430" spacing="15">
                <styleClass>
                    <String fx:value="auth-form-card"/>
                    <String fx:value="auth-register-card"/>
                </styleClass>
                <Hyperlink text="&#8592; Kembali ke Login" onAction="#goToLogin" styleClass="back-link"/>

                <VBox spacing="8">
                    <Label text="Daftar Akun Baru" styleClass="form-title"/>
                    <Label text="Lengkapi data di bawah untuk membuat akun" styleClass="form-subtitle"/>
                </VBox>

                <Label fx:id="errorLabel" styleClass="message-box" wrapText="true"/>

                <HBox spacing="14">
                    <VBox spacing="8" HBox.hgrow="ALWAYS">
                        <Label text="Nama Depan *" styleClass="input-label"/>
                        <TextField fx:id="firstNameField" promptText="Nama depan" styleClass="auth-input"/>
                    </VBox>
                    <VBox spacing="8" HBox.hgrow="ALWAYS">
                        <Label text="Nama Belakang *" styleClass="input-label"/>
                        <TextField fx:id="lastNameField" promptText="Nama belakang" styleClass="auth-input"/>
                    </VBox>
                </HBox>

                <VBox spacing="8">
                    <Label text="Email *" styleClass="input-label"/>
                    <TextField fx:id="emailField" promptText="nama@email.com" styleClass="auth-input"/>
                </VBox>

                <VBox spacing="8">
                    <Label text="Password *" styleClass="input-label"/>
                    <StackPane>
                        <PasswordField fx:id="passwordField" promptText="Minimal 8 karakter" styleClass="auth-input"/>
                        <TextField fx:id="visiblePasswordField" promptText="Minimal 8 karakter" styleClass="auth-input"/>
                    </StackPane>
                </VBox>

                <VBox spacing="8">
                    <Label text="Konfirmasi Password *" styleClass="input-label"/>
                    <StackPane>
                        <PasswordField fx:id="confirmPasswordField" promptText="Ulangi password" styleClass="auth-input"/>
                        <TextField fx:id="visibleConfirmPasswordField" promptText="Ulangi password" styleClass="auth-input"/>
                    </StackPane>
                    <CheckBox fx:id="showPasswordCheckBox" text="Tampilkan password" onAction="#handleTogglePassword" styleClass="small-check"/>
                </VBox>

                <VBox spacing="8">
                    <Label text="Foto Profil (opsional)" styleClass="input-label"/>
                    <VBox alignment="CENTER" spacing="8" styleClass="upload-box">
                        <ImageView fitWidth="30" fitHeight="30" preserveRatio="true" styleClass="upload-icon-image">
                            <viewport>
                                <Rectangle2D minX="33" minY="30" width="86" height="86"/>
                            </viewport>
                            <image>
                                <Image url="@../img/logo_nasibergizipajak.png"/>
                            </image>
                        </ImageView>
                        <Button text="Pilih foto profil" onAction="#handleChooseProfileImage" styleClass="upload-button"/>
                        <Label fx:id="profileImageLabel" text="PNG/JPG hingga 2MB" styleClass="upload-hint" wrapText="true"/>
                    </VBox>
                </VBox>

                <Button fx:id="registerButton" text="Daftar" onAction="#handleRegister" maxWidth="Infinity" styleClass="button-secondary"/>

                <HBox alignment="CENTER" spacing="4">
                    <Label text="Sudah punya akun?" styleClass="muted-text"/>
                    <Hyperlink text="Masuk di sini" onAction="#goToLogin">
                        <styleClass>
                            <String fx:value="auth-link"/>
                            <String fx:value="auth-link-orange"/>
                        </styleClass>
                    </Hyperlink>
                </HBox>
            </VBox>
        </ScrollPane>
    </StackPane>
</HBox>
