<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.geometry.Rectangle2D?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="nasi_bergizi_pajak.controller.DashboardController"
            stylesheets="@../auth.css"
            styleClass="userdash-root">

    <left>
        <VBox spacing="18" styleClass="userdash-sidebar">
            <padding>
                <Insets top="18" right="10" bottom="16" left="10"/>
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="10">
                <StackPane styleClass="userdash-logo-box">
                    <ImageView fitWidth="34" fitHeight="34" preserveRatio="true">
                        <viewport>
                            <Rectangle2D minX="33" minY="30" width="86" height="86"/>
                        </viewport>
                        <image>
                            <Image url="@../img/logo_nasibergizipajak.png"/>
                        </image>
                    </ImageView>
                </StackPane>
                <VBox spacing="0">
                    <Label text="Nasi Bergizi" styleClass="userdash-brand-title"/>
                    <Label text="Pajak" styleClass="userdash-brand-subtitle"/>
                </VBox>
            </HBox>

            <VBox spacing="8">
                <Label text="MENU UTAMA" styleClass="userdash-menu-title"/>
                <Button text="Dashboard" maxWidth="Infinity" styleClass="userdash-nav-active"/>
                <Button text="Profil Keluarga" maxWidth="Infinity" styleClass="userdash-nav-button"/>
                <Button text="Budget" maxWidth="Infinity" styleClass="userdash-nav-button"/>
                <Button text="Parameter Planner" maxWidth="Infinity" styleClass="userdash-nav-button"/>
                <Button text="Stok Dapur" maxWidth="Infinity" onAction="#handleStokDapur" styleClass="userdash-nav-button"/>
                <Button text="Menu Mingguan" maxWidth="Infinity" styleClass="userdash-nav-button"/>
                <Button text="Rekomendasi Menu" maxWidth="Infinity" styleClass="userdash-nav-button"/>
                <Button text="Shopping Planner" maxWidth="Infinity" styleClass="userdash-nav-button"/>
                <Button text="Hasil Belanja" maxWidth="Infinity" styleClass="userdash-nav-button"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <VBox spacing="8" styleClass="userdash-sidebar-footer">
                <Button text="Pengaturan" maxWidth="Infinity" styleClass="userdash-nav-button"/>
                <Button text="Logout" maxWidth="Infinity" onAction="#handleLogout" styleClass="userdash-nav-button"/>
            </VBox>
        </VBox>
    </left>

    <center>
        <VBox spacing="0" styleClass="userdash-main-area">
            <HBox alignment="CENTER_LEFT" spacing="14" styleClass="userdash-topbar">
                <padding>
                    <Insets top="14" right="22" bottom="14" left="22"/>
                </padding>

                <Label text="Dashboard" styleClass="userdash-page-title"/>
                <Label text="Budget: 22 Apr - 28 Apr" styleClass="userdash-period-badge"/>
                <Region HBox.hgrow="ALWAYS"/>
                <StackPane styleClass="userdash-bell">
                    <Label text="3" styleClass="userdash-bell-badge"/>
                </StackPane>
                <StackPane styleClass="userdash-avatar">
                    <Label text="N" styleClass="userdash-avatar-text"/>
                </StackPane>
                <VBox spacing="0">
                    <Label fx:id="welcomeLabel" text="Budi" styleClass="userdash-user-name"/>
                    <Label fx:id="emailLabel" text="" styleClass="userdash-user-email"/>
                </VBox>
            </HBox>

            <ScrollPane fitToWidth="true"
                        hbarPolicy="NEVER"
                        VBox.vgrow="ALWAYS"
                        styleClass="userdash-scroll">
                <content>
                    <VBox spacing="18" styleClass="userdash-content">
                        <padding>
                            <Insets top="18" right="22" bottom="28" left="22"/>
                        </padding>

                        <HBox spacing="14" fillHeight="true">
                            <HBox alignment="CENTER_LEFT" spacing="14" HBox.hgrow="ALWAYS" styleClass="userdash-summary-card">
                                <StackPane styleClass="userdash-icon-soft-orange">
                                    <Label text="3" styleClass="userdash-icon-number"/>
                                </StackPane>
                                <VBox spacing="4">
                                    <Label text="Anggota Keluarga" styleClass="userdash-card-title"/>
                                    <Label text="3" styleClass="userdash-card-value"/>
                                </VBox>
                            </HBox>

                            <HBox alignment="CENTER_LEFT" spacing="14" HBox.hgrow="ALWAYS" styleClass="userdash-summary-green">
                                <StackPane styleClass="userdash-icon-green">
                                    <Label text="Rp" styleClass="userdash-icon-text"/>
                                </StackPane>
                                <VBox spacing="4">
                                    <Label text="Sisa Budget" styleClass="userdash-card-title"/>
                                    <Label text="Rp385.000" styleClass="userdash-card-value-green"/>
                                </VBox>
                            </HBox>

                            <HBox alignment="CENTER_LEFT" spacing="14" HBox.hgrow="ALWAYS" styleClass="userdash-summary-card">
                                <StackPane styleClass="userdash-icon-soft-green">
                                    <Label text="6" styleClass="userdash-icon-number-green"/>
                                </StackPane>
                                <VBox spacing="4">
                                    <Label text="Stok Dapur" styleClass="userdash-card-title"/>
                                    <HBox spacing="5" alignment="BOTTOM_LEFT">
                                        <Label text="6" styleClass="userdash-card-value"/>
                                        <Label text="(3 aman)" styleClass="userdash-card-caption"/>
                                    </HBox>
                                </VBox>
                            </HBox>

                            <HBox alignment="CENTER_LEFT" spacing="14" HBox.hgrow="ALWAYS" styleClass="userdash-summary-card">
                                <StackPane styleClass="userdash-icon-soft-orange">
                                    <Label text="18" styleClass="userdash-icon-number"/>
                                </StackPane>
                                <VBox spacing="4">
                                    <Label text="Menu Minggu Ini" styleClass="userdash-card-title"/>
                                    <HBox spacing="4" alignment="BOTTOM_LEFT">
                                        <Label text="18/28" styleClass="userdash-card-value"/>
                                        <Label text="slot" styleClass="userdash-card-caption"/>
                                    </HBox>
                                </VBox>
                            </HBox>
                        </HBox>

                        <HBox spacing="18" fillHeight="true">
                            <VBox spacing="18" HBox.hgrow="ALWAYS">
                                <VBox spacing="18" styleClass="userdash-panel">
                                    <HBox alignment="CENTER_LEFT">
                                        <VBox spacing="2">
                                            <Label text="Status Budget" styleClass="userdash-section-title"/>
                                            <Label text="Periode: 22 Apr - 28 Apr 2024" styleClass="userdash-section-subtitle"/>
                                        </VBox>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Button text="Kelola  >" styleClass="userdash-small-button"/>
                                    </HBox>

                                    <HBox spacing="12">
                                        <VBox spacing="5" HBox.hgrow="ALWAYS" styleClass="userdash-budget-box">
                                            <Label text="Total Budget" styleClass="userdash-budget-label"/>
                                            <Label text="Rp500.000" styleClass="userdash-budget-value-dark"/>
                                        </VBox>
                                        <VBox spacing="5" HBox.hgrow="ALWAYS" styleClass="userdash-budget-box-orange">
                                            <Label text="Terpakai" styleClass="userdash-budget-label"/>
                                            <Label text="Rp115.000" styleClass="userdash-budget-value-orange"/>
                                        </VBox>
                                        <VBox spacing="5" HBox.hgrow="ALWAYS" styleClass="userdash-budget-box-green">
                                            <Label text="Sisa" styleClass="userdash-budget-label"/>
                                            <Label text="Rp385.000" styleClass="userdash-budget-value-green"/>
                                        </VBox>
                                    </HBox>

                                    <VBox spacing="8">
                                        <HBox alignment="CENTER_LEFT">
                                            <Label text="Penggunaan" styleClass="userdash-section-subtitle"/>
                                            <Region HBox.hgrow="ALWAYS"/>
                                            <Label text="23%" styleClass="userdash-percent"/>
                                        </HBox>
                                        <ProgressBar progress="0.23" maxWidth="Infinity" styleClass="userdash-progress"/>
                                    </VBox>

                                    <HBox alignment="CENTER_LEFT">
                                        <Label text="Status" styleClass="userdash-section-subtitle"/>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Label text="Aman" styleClass="userdash-safe-badge"/>
                                    </HBox>
                                </VBox>
                            </VBox>

                            <VBox spacing="18" prefWidth="380" minWidth="340" styleClass="userdash-panel">
                                <HBox alignment="CENTER_LEFT" spacing="8">
                                    <Label text="!" styleClass="userdash-warning-icon"/>
                                    <Label text="Notifikasi Sistem" styleClass="userdash-section-title"/>
                                </HBox>

                                <VBox spacing="0">
                                    <VBox spacing="3" styleClass="userdash-alert-row">
                                        <Label text="Bahan Hampir Kadaluarsa" styleClass="userdash-alert-title"/>
                                        <Label text="2 bahan perlu diperhatikan" styleClass="userdash-alert-subtitle"/>
                                    </VBox>
                                    <VBox spacing="3" styleClass="userdash-alert-row">
                                        <Label text="Stok Bahan Hampir Habis" styleClass="userdash-alert-title"/>
                                        <Label text="1 bahan perlu diisi ulang" styleClass="userdash-alert-subtitle"/>
                                    </VBox>
                                </VBox>
                            </VBox>
                        </HBox>

                        <HBox spacing="18" fillHeight="true">
                            <VBox spacing="18" HBox.hgrow="ALWAYS" styleClass="userdash-panel">
                                <HBox alignment="CENTER_LEFT">
                                    <VBox spacing="2">
                                        <Label text="Peringatan Stok" styleClass="userdash-section-title"/>
                                        <Label text="Bahan yang perlu diperhatikan" styleClass="userdash-section-subtitle"/>
                                    </VBox>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Button text="Lihat Semua" styleClass="userdash-small-button"/>
                                </HBox>

                                <VBox spacing="8">
                                    <Label text="HAMPIR KADALUARSA" styleClass="userdash-group-label"/>
                                    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="userdash-stock-row-orange">
                                        <VBox spacing="2">
                                            <Label text="Ayam" styleClass="userdash-stock-title"/>
                                            <Label text="0.5 kg" styleClass="userdash-stock-subtitle"/>
                                        </VBox>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Label text="Hampir Kadaluarsa" styleClass="userdash-chip-orange"/>
                                    </HBox>
                                    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="userdash-stock-row-orange">
                                        <VBox spacing="2">
                                            <Label text="Bayam" styleClass="userdash-stock-title"/>
                                            <Label text="1 ikat" styleClass="userdash-stock-subtitle"/>
                                        </VBox>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Label text="Hampir Kadaluarsa" styleClass="userdash-chip-orange"/>
                                    </HBox>

                                    <Label text="STOK MENIPIS" styleClass="userdash-group-label"/>
                                    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="userdash-stock-row">
                                        <VBox spacing="2">
                                            <Label text="Telur" styleClass="userdash-stock-title"/>
                                            <Label text="6 butir" styleClass="userdash-stock-subtitle"/>
                                        </VBox>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Label text="Hampir Habis" styleClass="userdash-chip-orange"/>
                                    </HBox>
                                </VBox>
                            </VBox>

                            <VBox spacing="18" HBox.hgrow="ALWAYS" styleClass="userdash-panel">
                                <VBox spacing="2">
                                    <Label text="Status Aktivitas" styleClass="userdash-section-title"/>
                                    <Label text="Ringkasan aktivitas terkini" styleClass="userdash-section-subtitle"/>
                                </VBox>

                                <VBox spacing="10">
                                    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="userdash-activity-row">
                                        <VBox spacing="2">
                                            <Label text="Menu Mingguan" styleClass="userdash-stock-title"/>
                                            <Label text="22 Apr - 28 Apr" styleClass="userdash-stock-subtitle"/>
                                        </VBox>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <VBox alignment="CENTER_RIGHT" spacing="2">
                                            <Label text="Rp385.000" styleClass="userdash-budget-value-orange-small"/>
                                            <Label text="estimasi" styleClass="userdash-stock-subtitle"/>
                                        </VBox>
                                    </HBox>

                                    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="userdash-activity-row">
                                        <VBox spacing="2">
                                            <Label text="Shopping Planner" styleClass="userdash-stock-title"/>
                                            <Label text="21 Apr 2024" styleClass="userdash-stock-subtitle"/>
                                        </VBox>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Label text="Dalam Proses" styleClass="userdash-chip-orange"/>
                                    </HBox>
                                </VBox>

                                <HBox spacing="10">
                                    <Button text="Profil Keluarga" maxWidth="Infinity" HBox.hgrow="ALWAYS" styleClass="userdash-quick-button"/>
                                    <Button text="Rekomendasi" maxWidth="Infinity" HBox.hgrow="ALWAYS" styleClass="userdash-quick-button"/>
                                </HBox>
                            </VBox>
                        </HBox>
                    </VBox>
                </content>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>
